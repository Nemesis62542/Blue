  id: 4
  dialogueLines:
  - text: "\u305D\u3053\u304B\u3089\u5148\u306B\u3001\u300C\u30EB\u30FC\u30C8\u30B1\u30A4\u30D6\u300D\u3068\u3044\u3046\u6D1E\u7A9F\u304C\u5E83\u304C\u3063\u3066\u3044\u307E\u3059\u3002"
  - text: "\u5927\u6614\u306B\u5730\u4E0A\u304B\u3089\u6D41\u308C\u305F\u6C34\u304C\u5730\u9762\u3092\u524A\u308A\u3001\u6728\u306E\u6839\u306E\u3088\u3046\u306A\u6D1E\u7A9F\u3092\u5F62\u6210\u3057\u3066\u3044\u308B\u3053\u3068\u304C\u7531\u6765\u3067\u3059\u3002"
  - text: "\u3082\u3061\u308D\u3093\u304A\u5BA2\u69D8\u3082\u63A2\u7D22\u3059\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u304C\u3001\u304B\u306A\u308A\u5165\u308A\u7D44\u3093\u3060\u5730\u5F62\u306E\u4E0A\u3001\u30C8\u30E9\u30D6\u30EB\u306E\u969B\u306B\u6551\u52A9\u306B\u5411\u304B\u3046\u3053\u3068\u304C\u56F0\u96E3\u3067\u3059\u3002"
  - text: "\u7D30\u5FC3\u306E\u6CE8\u610F\u3092\u6255\u3063\u3066\u63A2\u7D22\u3057\u3066\u304F\u3060\u3055\u3044\u3002"
  timelineAsset: {fileID: 11400000, guid: cae1d9c6c288b054298e16f024ef8630, type: 2}
  isMovie: 0
