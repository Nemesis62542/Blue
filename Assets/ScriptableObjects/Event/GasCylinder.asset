  id: 2
  dialogueLines:
  - text: "\u53F3\u624B\u306E\u65B9\u306B\u3001\u9178\u7D20\u30DC\u30F3\u30D9\u304C\u3042\u308B\u306E\u304C\u898B\u3048\u3066\u3044\u307E\u3059\u304B\uFF1F"
  - text: "\u5F53\u793E\u652F\u7D66\u306E\u6F5C\u6C34\u30BF\u30F3\u30AF\u3067\u3042\u308C\u30705\u5206\u307B\u3069\u6D3B\u52D5\u304C\u53EF\u80FD\u3067\u3059\u304C\u3001\u9178\u7D20\u30DC\u30F3\u30D9\u306F\u3044\u3064\u3067\u3082\u4F7F\u7528\u53EF\u80FD\u3067\u3059\u306E\u3067\u3001\u3054\u81EA\u7531\u306B\u304A\u4F7F\u3044\u304F\u3060\u3055\u3044\u3002"
  - text: "\u6E96\u5099\u304C\u6574\u3044\u307E\u3057\u305F\u3089\u3001\u305D\u306E\u96A3\u308A\u306B\u3042\u308B\u6D1E\u7A9F\u3092\u629C\u3051\u3066\u304F\u3060\u3055\u3044\u3002"
