  m_Script: {fileID: 11500000, guid: b476467b497ad124a918b6cccff1776a, type: 3}
  m_Name: CaptureGun
  m_EditorClassIdentifier: 
  id: 3
  dialogueLines:
  - text: "\u6D1E\u7A9F\u3092\u629C\u3051\u305F\u5148\u306B\u3001\u7269\u8CC7\u3092\u6295\u4E0B\u3055\u305B\u3066\u3044\u305F\u3060\u304D\u307E\u3057\u305F\u3002\n\u4E2D\u306B\u306F\u300C\u30AD\u30E3\u30D7\u30C1\u30E3\u30FC\u30AC\u30F3\u300D\u304C\u5165\u3063\u3066\u304A\u308A\u307E\u3059\u3002"
  - text: "\u3053\u308C\u304B\u3089\u3001\u304A\u5BA2\u69D8\u306B\u306F\u672C\u30D7\u30ED\u30B0\u30E9\u30E0\u306E\u76EE\u7389\u3067\u3042\u308B\u300C\u751F\u614B\u8ABF\u67FB\u30FB\u751F\u7269\u306E\u6355\u7372\u300D\u3092\u4F53\u9A13\u3057\u3066\u3044\u305F\u3060\u304D\u307E\u3059\u3002"
  - text: "\u30AD\u30E3\u30D7\u30C1\u30E3\u30FC\u30AC\u30F3\u3092\u624B\u306B\u6301\u3063\u3066\u4F7F\u7528\u3059\u308B\u3053\u3068\u3067\u3001\u7279\u6B8A\u306A\u5149\u5F3E\u3092\u767A\u5C04\u3057\u3001\u751F\u7269\u3092\u6355\u7372\u3059\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002"
  - text: "<\u30DE\u30A6\u30B9\u30DB\u30A4\u30FC\u30EB\u30AF\u30EA\u30C3\u30AF>\u3067\u3001\u5468\u56F2\u306E\u751F\u7269\u3092\u30B9\u30AD\u30E3\u30F3\u3067\u304D\u307E\u3059\u3002"
  timelineAsset: {fileID: 11400000, guid: d20d9513a9e6bcb4aa743ebce711abb9, type: 2}
  isMovie: 0
