  m_Name: GetMegalo
  m_EditorClassIdentifier: 
  id: 7
  dialogueLines:
  - text: "...\u901A\u4FE1\u304C...!\n\u304A\u5BA2\u69D8\u3001\u805E\u3053\u3048\u3066\u3044\u307E\u3059\u304B\uFF1F"
  - text: "\u73FE\u5728\u4F4D\u7F6E\u306F......\n!?"
  - text: "\u3069...\u3069\u3046\u3084\u3089\u3001\u5076\u7136\u30EB\u30FC\u30C8\u30B1\u30A4\u30D6\u306E\u30D6\u30EB\u30FC\u30DB\u30FC\u30EB\u90E8\u5206\u307E\u3067\u305F\u3069\u308A\u7740\u3051\u305F\u3088\u3046\u3067\u3059\u306D\u3002\n\u7121\u4E8B\u3067\u4F55\u3088\u308A\u3067\u3054\u3056\u3044\u307E\u3059\u3002"
  - text: "\u52A0\u3048\u3066\u305D\u306E\u4ED8\u8FD1\u306F\u5F0A\u793E\u306E\u7BA1\u7406\u3057\u3066\u3044\u308B\u533A\u57DF\u3082\u8FD1\u3044...\u3067\u306F\u3001\u3059\u3050\u306B\u6551\u52A9\u3092\u5411\u304B\u308F\u305B\u307E\u3059\u306E\u3067\u3001\u305D\u306E\u5834\u3067\u304A\u5F85\u3061\u4E0B\u3055\u3044\u3002"
  - text: "...\u305D\u308C\u3068\u3001\u3082\u3057\u304B\u3059\u308B\u3068\u5F0A\u793E\u304C\u6240\u6709\u3059\u308B\u6A5F\u5668\u985E\u304C\u305D\u306E\u4ED8\u8FD1\u306B\u3042\u308B\u304B\u3082\u3057\u308C\u307E\u305B\u3093\u304C...\u3053\u3061\u3089\u306F\u3069\u3046\u304B\u3001\u304A\u624B\u3092\u89E6\u308C\u306A\u3044\u3088\u3046\u306B\u304A\u9858\u3044\u3044\u305F\u3057\u307E\u3059\u3002"
  - text: "\u3053\u306E\u3042\u3068\u306F\u6C34\u65CF\u9928\u306B\u3066\u3001\u304A\u5BA2\u69D8\u304C\u6355\u7372\u3057\u305F\u751F\u7269\u3092\u5C55\u793A\u3057\u3066\u3044\u307E\u3059\u306E\u3067\u3001\u305C\u3072\u3054\u89A7\u304F\u3060\u3055\u3044\uFF01"
  timelineAsset: {fileID: 11400000, guid: 840ce3e5b9a249c49b6a87bddd8fbbd7, type: 2}
  isMovie: 1
