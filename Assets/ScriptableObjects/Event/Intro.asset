  id: 1
  dialogueLines:
  - text: "...\u4ECA\u56DE\u306F\u3001\u30A2\u30C8\u30E9\u30F3\u30C6\u30A3\u30B9\u793E\u306E\u6D77\u4E2D\u63A2\u691C\u30D7\u30ED\u30B0\u30E9\u30E0\u3078\u306E\u3054\u53C2\u52A0\u3001\u8AA0\u306B\u3042\u308A\u304C\u3068\u3046\u3054\u3056\u3044\u307E\u3059\u3002"
  - text: "\u672C\u30D7\u30ED\u30B0\u30E9\u30E0\u3067\u306F\u3001\u3053\u306E\u8B0E\u591A\u304D\u6D77\u57DF\u300C\u30CD\u30E2\u300D\u306E\u6D45\u702C\u533A\u57DF\u306E\u63A2\u7D22\u3092\u884C\u3044\u307E\u3059\u3002"
  - text: "\u307E\u305A\u306F\u3001\u6D77\u4E2D\u3067\u306E\u79FB\u52D5\u306B\u6163\u308C\u307E\u3057\u3087\u3046\u3002"
  - text: "\u9053\u306A\u308A\u306B\u9032\u3093\u3067\u304F\u3060\u3055\u3044\u3002"
